{
  "name": "@vsceasy/cli",
  "version": "0.1.5",
  "description": "Build VS Code extensions fast — React UI + typed RPC bridge between extension and webview + file-based routing for panels, commands, menus, tree views, and subpanels.",
  "main": "dist/index.js",
  "scripts": {
    "pretest": "bun run embed:templates",
    "test": "bun test ./src/tests",
    "gen:types": "bun scripts/genCodiconTypes.ts",
    "sync:runtime": "bun scripts/syncRuntime.ts",
    "embed:templates": "bun scripts/embedTemplates.ts",
    "build:runtime": "cd packages/vsceasy-runtime && bun install && bunx tsc",
    "build": "bun run gen:types && bun run sync:runtime && bun run embed:templates && bun run build:runtime && tsc --emitDeclarationOnly && bun build ./src/index.ts ./src/bin/cli.ts --target=node --outdir ./dist --format cjs",
    "build:test": "bun build ./src/tests/*.ts --target=node --outdir dist/tests --format cjs",
    "prepublishOnly": "bun run build",
    "start": "bun run src/cli.ts",
    "lint": "eslint 'src/**/*.ts'",
    "lint:fix": "eslint 'src/**/*.ts' --fix",
    "format": "prettier --write 'src/**/*.{ts,tsx,json,md}' '*.md'",
    "format:check": "prettier --check 'src/**/*.{ts,tsx,json,md}' '*.md'",
    "release:patch": "npm version patch -m 'chore(release): %s'",
    "release:minor": "npm version minor -m 'chore(release): %s'",
    "release:major": "npm version major -m 'chore(release): %s'"
  },
  "keywords": [
    "vscode",
    "vscode-extension",
    "framework",
    "scaffold",
    "cli",
    "react",
    "webview",
    "rpc"
  ],
  "author": "Jairo <jairofg12@gmail.com>",
  "license": "MIT",
  "type": "commonjs",
  "bin": {
    "vsceasy": "dist/bin/cli.js"
  },
  "types": "dist/index.d.ts",
  "files": [
    "dist/**/*",
    "templates/**/*",
    "LICENSE",
    "README.md",
    "CHANGELOG.md",
    "!src/tests/**/*"
  ],
  "engines": {
    "node": ">=24.11.1"
  },
  "homepage": "https://vsceasy.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jairoFernandez/vsceasy.git"
  },
  "bugs": {
    "url": "https://github.com/jairoFernandez/vsceasy/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@types/vscode": "^1.43.2",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.3.0",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@ideascol/cli-maker": "^2.2.2"
  }
}
