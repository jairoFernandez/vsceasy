{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "./dist",
    "types": ["node"],
    "declaration": true,
    "declarationMap": true,
    "declarationDir": "./dist"
  },
  "exclude": ["node_modules"]
}
