{
  "name": "vsceasy-runtime",
  "version": "0.1.0",
  "description": "Runtime for vsceasy — bootstrap(registry), define* helpers, RPC bridge for VS Code extensions.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "default": "./dist/client.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist/**/*",
    "src/**/*",
    "LICENSE",
    "README.md"
  ],
  "license": "MIT",
  "author": "Jairo <jairofg12@gmail.com>",
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "@types/vscode": ">=1.43.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@types/vscode": "^1.43.2",
    "typescript": "^6.0.3"
  }
}
